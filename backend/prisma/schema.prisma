generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Usuário ────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  avatarUrl    String?
  householdId  String?

  household     Household?     @relation(fields: [householdId], references: [id])
  refreshTokens RefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// ─── Household (Casa / Família) ──────────────────────────────────────────────

model Household {
  id       String @id @default(cuid())
  name     String
  currency String @default("BRL")

  users        User[]
  accounts     Account[]
  cards        Card[]
  categories   Category[]
  transactions Transaction[]
  budgets      Budget[]
  goals        Goal[]
  investments  Investment[]
  invites      Invite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("households")
}

// ─── Conta Bancária ──────────────────────────────────────────────────────────

model Account {
  id          String      @id @default(cuid())
  householdId String
  name        String
  type        AccountType
  bank        String?
  balance     Decimal     @default(0) @db.Decimal(15, 2)
  currency    String      @default("BRL")
  color       String?
  icon        String?
  isActive    Boolean     @default(true)

  household        Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  transactionsFrom Transaction[] @relation("TransactionFromAccount")
  transactionsTo   Transaction[] @relation("TransactionToAccount")
  cards            Card[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("accounts")
}

enum AccountType {
  CHECKING
  SAVINGS
  INVESTMENT
  CASH
  OTHER
}

// ─── Cartão de Crédito ────────────────────────────────────────────────────────

model Card {
  id             String    @id @default(cuid())
  householdId    String
  accountId      String?
  name           String
  lastFourDigits String?
  brand          CardBrand @default(OTHER)
  creditLimit    Decimal   @db.Decimal(15, 2)
  billingDay     Int
  dueDay         Int
  color          String?
  isActive       Boolean   @default(true)
  isFrozen       Boolean   @default(false)

  household    Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  account      Account?      @relation(fields: [accountId], references: [id])
  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cards")
}

enum CardBrand {
  VISA
  MASTERCARD
  ELO
  AMEX
  HIPERCARD
  OTHER
}

// ─── Categoria ────────────────────────────────────────────────────────────────

model Category {
  id          String          @id @default(cuid())
  householdId String
  name        String
  type        TransactionType
  icon        String?
  color       String?
  parentId    String?
  isDefault   Boolean         @default(false)

  household    Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  parent       Category?     @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children     Category[]    @relation("CategoryHierarchy")
  transactions Transaction[]
  budgets      Budget[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

// ─── Transação ────────────────────────────────────────────────────────────────

model Transaction {
  id              String          @id @default(cuid())
  householdId     String
  accountId       String?
  toAccountId     String?
  cardId          String?
  categoryId      String?
  type            TransactionType
  amount          Decimal         @db.Decimal(15, 2)
  description     String?
  date            DateTime
  isPaid          Boolean         @default(true)
  isRecurring     Boolean         @default(false)
  recurrenceRule  String?
  notes           String?
  attachments     String[]

  household   Household  @relation(fields: [householdId], references: [id], onDelete: Cascade)
  account     Account?   @relation("TransactionFromAccount", fields: [accountId], references: [id])
  toAccount   Account?   @relation("TransactionToAccount", fields: [toAccountId], references: [id])
  card        Card?      @relation(fields: [cardId], references: [id])
  category    Category?  @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([householdId, date])
  @@index([householdId, type])
  @@map("transactions")
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

// ─── Orçamento ────────────────────────────────────────────────────────────────

model Budget {
  id          String       @id @default(cuid())
  householdId String
  categoryId  String?
  name        String
  amount      Decimal      @db.Decimal(15, 2)
  period      BudgetPeriod @default(MONTHLY)
  month       Int?
  year        Int?
  isActive    Boolean      @default(true)

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  category  Category? @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("budgets")
}

enum BudgetPeriod {
  MONTHLY
  WEEKLY
  YEARLY
  CUSTOM
}

// ─── Meta Financeira ─────────────────────────────────────────────────────────

model Goal {
  id            String    @id @default(cuid())
  householdId   String
  name          String
  targetAmount  Decimal   @db.Decimal(15, 2)
  currentAmount Decimal   @default(0) @db.Decimal(15, 2)
  targetDate    DateTime?
  icon          String?
  color         String?
  isCompleted   Boolean   @default(false)

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("goals")
}

// ─── Convite ─────────────────────────────────────────────────────────────────

model Invite {
  id          String    @id @default(cuid())
  householdId String
  email       String
  token       String    @unique
  expiresAt   DateTime
  acceptedAt  DateTime?

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("invites")
}

// ─── Investimento ─────────────────────────────────────────────────────────────

model Investment {
  id            String         @id @default(cuid())
  householdId   String
  name          String
  type          InvestmentType
  ticker        String?
  quantity      Decimal?       @db.Decimal(15, 6)
  purchasePrice Decimal?       @db.Decimal(15, 2)
  currentPrice  Decimal?       @db.Decimal(15, 2)
  purchaseDate  DateTime?
  broker        String?
  notes         String?

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("investments")
}

enum InvestmentType {
  STOCK
  FUND
  BOND
  CRYPTO
  REAL_ESTATE
  SAVINGS
  OTHER
}

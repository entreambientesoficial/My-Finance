# ─── Database (Supabase) ──────────────────────────────────────────────────────
# Transaction pooler (porta 6543) — usado em runtime pelo Prisma Client
DATABASE_URL="postgresql://postgres.qovqkvcvlrzmtvufursn:[YOUR-PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Conexão direta (porta 5432) — usada por `prisma migrate deploy` e `prisma db push`
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.qovqkvcvlrzmtvufursn.supabase.co:5432/postgres"

# ─── Redis (não utilizado — pode omitir) ──────────────────────────────────────
# REDIS_URL="redis://localhost:6379"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-secret-in-production-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-this-refresh-secret-in-production-min-32-chars"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:3000"

# ─── SMTP (notificações por e-mail — opcional, suprimido se vazio) ────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="MY-FINANCE <no-reply@myfinance.app>"

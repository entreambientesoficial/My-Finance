# ─── Database (Supabase) ──────────────────────────────────────────────────────
# Pooler PgBouncer para queries em produção (porta 6543)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Conexão direta para migrations (porta 5432)
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="gere-um-segredo-forte-de-128-chars-hex"
JWT_REFRESH_SECRET="gere-outro-segredo-forte-de-128-chars-hex"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://meudominio.com"

# ─── Supabase Storage (avatars) ───────────────────────────────────────────────
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_SERVICE_KEY="sb_secret_..."

# ─── Resend (e-mail — opcional) ───────────────────────────────────────────────
RESEND_API_KEY=""
MAIL_FROM="MY-FINANCE <noreply@meudominio.com>"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized redirect URIs: https://meudominio.com/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── brapi.dev (cotações — opcional, aumenta limite de requisições) ────────────
BRAPI_TOKEN=""
